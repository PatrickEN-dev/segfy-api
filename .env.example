# Template das variaveis de ambiente do docker-compose.
# Copie para .env (git-ignored) e ajuste se precisar. Todos os defaults funcionam.

# Porta do teu computador que abre pra API.
API_PORT=8080

# Onde o SQLite fica dentro do container.
CONNECTION_STRING=Data Source=/app/data/segfy.db;Cache=Shared

# Janela para /policies/expiring (dias, 1..365).
EXPIRING_WINDOW_DAYS=30

# Liga o job em background que marca apolices vencidas como Expirada.
AUTO_EXPIRATION_ENABLED=true

# Intervalo do job em segundos (60..86400).
AUTO_EXPIRATION_INTERVAL_SECONDS=3600

# Popula 6 apolices de exemplo no primeiro boot se o banco estiver vazio.
SEED_SAMPLE_DATA=true
