# Copy to `.env` and adjust for your environment. `.env` is git-ignored.
# All variables use ASP.NET Core's `__` convention to map to `appsettings.json`
# sections (e.g. Segfy__ExpiringWindowDays -> Segfy:ExpiringWindowDays).

ASPNETCORE_ENVIRONMENT=Production
# When running via docker-compose, the host port that maps to container 8080.
API_PORT=8080


# Path is inside the container. Change if you mount a different volume.
CONNECTION_STRING=Data Source=/app/data/segfy.db;Cache=Shared

# ---- Domain configuration ----
# Days ahead considered in GET /policies/expiring (1..365)
EXPIRING_WINDOW_DAYS=30

# Toggle the background auto-expiration job.
AUTO_EXPIRATION_ENABLED=true

# Interval between auto-expiration passes, in seconds (60..86400).
AUTO_EXPIRATION_INTERVAL_SECONDS=3600
